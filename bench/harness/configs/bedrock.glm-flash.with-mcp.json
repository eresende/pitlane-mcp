{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "amazon-bedrock"
  ],
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1"
      }
    }
  },
  "model": "amazon-bedrock/zai.glm-4.7-flash",
  "permission": "allow",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "mcp": {
    "pitlane": {
      "type": "local",
      "command": [
        "/home/eresende/projects/pitlane-mcp/target/debug/pitlane-mcp"
      ],
      "environment": {
        "PITLANE_EMBED_URL": "http://localhost:11434/api/embed",
        "PITLANE_EMBED_MODEL": "nomic-embed-text",
        "PITLANE_EMBED_BATCH_SIZE": "32",
        "PITLANE_EMBED_TIMEOUT": "256"
      }
    }
  }
}
