{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "amazon-bedrock"
  ],
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1"
      }
    }
  },
  "model": "amazon-bedrock/global.anthropic.claude-sonnet-4-5-20250929-v1:0",
  "permission": "allow",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "mcp": {
    "pitlane": {
      "type": "local",
      "command": [
        "/home/eresende/projects/pitlane-mcp/target/debug/pitlane-mcp"
      ],
      "environment": {
        "PITLANE_EMBED_URL": "http://127.0.0.1:1234/v1/embeddings",
        "PITLANE_EMBED_MODEL": "nomic-embed-text-v1.5",
        "PITLANE_EMBED_BATCH_SIZE": "256",
        "PITLANE_EMBED_TIMEOUT": "120"
      }
    }
  }
}
