{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "openai"
  ],
  "provider": {
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5.4-nano": {
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  },
  "model": "openai/gpt-5.4-nano",
  "permission": "allow",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
