{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "openai"
  ],
  "provider": {
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5.4-nano": {
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  },
  "model": "openai/gpt-5.4-nano",
  "permission": "allow",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "mcp": {
    "pitlane": {
      "type": "local",
      "command": [
        "pitlane-mcp"
      ],
      "environment": {
        "PITLANE_EMBED_URL": "http://localhost:11434/api/embed",
        "PITLANE_EMBED_MODEL": "nomic-embed-text",
        "PITLANE_EMBED_BATCH_SIZE": "256",
        "PITLANE_EMBED_TIMEOUT": "120"
      }
    }
  }
}
